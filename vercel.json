{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "devCommand": "expo start --web",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.marcadordepontos.com.br"
        }
      ],
      "destination": "https://marcadordepontos.com.br/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/listajogos",
      "destination": "/listajogos/index.html"
    },
    {
      "source": "/listajogos/",
      "destination": "/listajogos/index.html"
    },
    {
      "source": "/cacheta",
      "destination": "/cacheta/index.html"
    },
    {
      "source": "/cacheta/",
      "destination": "/cacheta/index.html"
    },
    {
      "source": "/truco",
      "destination": "/truco/index.html"
    },
    {
      "source": "/truco/",
      "destination": "/truco/index.html"
    },
    {
      "source": "/como-jogar-truco",
      "destination": "/como-jogar-truco/index.html"
    },
    {
      "source": "/como-jogar-truco/",
      "destination": "/como-jogar-truco/index.html"
    },
    {
      "source": "/como-jogar-cacheta",
      "destination": "/como-jogar-cacheta/index.html"
    },
    {
      "source": "/como-jogar-cacheta/",
      "destination": "/como-jogar-cacheta/index.html"
    },
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/:path*/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}