{
  "expo": {
    "name": "Marcador de Pontos",
    "slug": "marcador-de-baralho",
    "version": "2.0.16",
    "icon": "./assets/icons/playstore.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "schemes": [
      "myapp"
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icons/playstore.png"
    },
    "android": {
      "package": "dev.andre100.marcadorPontos",
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/playstore.png",
        "backgroundColor": "#FFFFFF"
      },
      "navigationBar": {
        "visible": "immersive"
      },
      "googleMobileAdsAppId": "ca-app-pub-7478664676745892~3869488742"
    },
    "ios": {
      "googleMobileAdsAppId": "ca-app-pub-7478664676745892~3869488742"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7478664676745892~3869488742",
          "iosAppId": "ca-app-pub-7478664676745892~3869488742"
        }
      ]
    ],
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-7478664676745892~3869488742",
      "ios_app_id": "ca-app-pub-7478664676745892~3869488742"
    },
    "extra": {
      "eas": {
        "projectId": "c7c0c4cd-650e-4e97-8656-c462dce3c3d1"
      }
    }
  }
}
