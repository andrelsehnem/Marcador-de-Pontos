{
  "name": "marcador-de-baralho",
  "version": "2.0.14",
  "description": "Acompanhe suas mãos e jogadas",
  "scripts": {
    "start": "expo start",
    "startClear": "expo start --clear",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/sync-head.js && node scripts/inject-adsense.js && node scripts/generate-seo-files.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:store": "cd android && gradlew.bat bundleRelease",
    "playStore": "call \"Build Android.bat\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@vercel/analytics": "^1.6.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-linking": "~8.0.11",
    "expo-navigation-bar": "~5.0.10",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.9",
    "expo-status-bar": "~3.0.9",
    "lucide-react": "^0.563.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.2.1",
    "react-native-iap": "^14.7.17",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.3.0"
  }
}
